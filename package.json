{
  "name": "@kafelix496/ts-library-template",
  "version": "1.0.0",
  "description": "Typescript library template",
  "main": "./cjs/index.js",
  "exports": {
    ".": {
      "require": "./cjs/index.js",
      "import": "./es/index.js",
      "default": "./cjs/index.js"
    },
    "./es/": "./es/",
    "./cjs/": "./cjs/",
    "./dist/": "./dist/"
  },
  "module": "./es/index.js",
  "unpkg": "dist/customLibraryTemplate.min.js",
  "sideEffects": false,
  "devDependencies": {
    "@babel/core": "^7.11.5",
    "@babel/preset-env": "^7.11.5",
    "@rollup/plugin-babel": "^5.2.0",
    "@rollup/plugin-node-resolve": "^9.0.0",
    "@types/jest": "^26.0.19",
    "@typescript-eslint/eslint-plugin": "^4.10.0",
    "@typescript-eslint/parser": "^4.10.0",
    "eslint": "^7.15.0",
    "eslint-config-standard": "^16.0.2",
    "eslint-config-standard-with-typescript": "^19.0.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^23.20.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^5.0.0",
    "husky": "^4.2.5",
    "jest": "^26.4.2",
    "lint-staged": "^10.2.13",
    "rimraf": "^3.0.2",
    "rollup": "^2.26.9",
    "rollup-plugin-terser": "^7.0.1",
    "rollup-plugin-typescript2": "^0.29.0",
    "ts-jest": "^26.4.4",
    "tslib": "^2.0.3",
    "typescript": "^4.1.3"
  },
  "scripts": {
    "test": "jest",
    "lint": "eslint '**/*.ts'",
    "lint:fix": "eslint --fix '**/*.ts'",
    "prebuild": "rimraf es cjs dist",
    "build": "rollup --config && node ./scripts/copyIndexFile.js"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kafelix496/js-library-template.git"
  },
  "keywords": [
    "typescript",
    "library",
    "template"
  ],
  "author": "Felix J Lee",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kafelix496/js-library-template/issues"
  },
  "homepage": "https://github.com/kafelix496/js-library-template#readme",
  "files": [
    "es",
    "cjs",
    "dist"
  ],
  "dependencies": {
    "@babel/preset-typescript": "^7.12.7",
    "enquirer": "^2.3.6"
  }
}
